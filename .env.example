# Search-Pro public snapshot local configuration.
# Copy values into your local environment or a credential manager.
# Do not commit real credentials.

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=https://localhost:5001;http://localhost:5000

# Use a mock or local-only database for public demos.
DATABASE_CONNECTION_STRING=REPLACE_WITH_LOCAL_MOCK_CONNECTION_STRING
REPORTING_CONNECTION_STRING=REPLACE_WITH_LOCAL_MOCK_REPORTING_CONNECTION_STRING

# LLM provider settings. Keep real values outside git.
LLM_PROVIDER_TOKEN=REPLACE_WITH_LOCAL_PROVIDER_TOKEN
LLM_PROVIDER_ENDPOINT=REPLACE_WITH_PROVIDER_ENDPOINT
LLM_PROVIDER_MODEL=REPLACE_WITH_MODEL_NAME
LLM_TIMEOUT_SECONDS=60
LLM_MAX_ROWS=200
LLM_LOG_SQL_TEXT=false
SQL_VIEW_UNLOCK_TOKEN=REPLACE_WITH_LOCAL_ONLY_UNLOCK_TOKEN

# NL2SQL runtime flags.
NL2SQL_CORE_V2=true
NL2SQL_FAILURE_COLLECTION=false
NL2SQL_LAB_VERSION=portfolio-sanitized
NL2SQL_FAILURE_COLLECTION_PATH=./work/nl2sql-failures
